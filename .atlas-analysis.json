  "keyFeatures": [
    "Interactive TUI for exploring Docker image layers",
    "Visual file tree with change indicators (added, modified, removed, unmodified)",
    "Image efficiency scoring and wasted space estimation",
    "Build and analyze images in one command (dive build)",
    "CI integration with pass/fail based on configurable rules",
    "Multiple image sources: Docker engine, Podman engine, Docker archive",
    "JSON export of layer analysis results",
    "Fully customizable keybindings"
  ],
  "publicApiSurface": [
    "dive <image>",
    "dive build [docker build args]",
    "dive --source <docker|podman|docker-archive> <image>",
    "dive --ci <image> (CI mode)",
    "dive --json <path> <image> (JSON export)",
    "--lowestEfficiency <ratio>",
    "--highestWastedBytes <bytes>",
    "--highestUserWastedPercent <ratio>",
    "CI config rules: lowestEfficiency, highestWastedBytes, highestUserWastedPercent"
  ]
